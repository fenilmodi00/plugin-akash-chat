{
  "name": "@elizaos/plugin-akash-chat",
  "version": "1.0.0-beta.32",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos-plugins/plugin-akash-chat"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/core": "^1.0.0-beta.32",
    "@elizaos/plugin-local-ai": "1.0.0-beta.32",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "prettier --write ./src",
    "clean": "rm -rf dist .turbo node_modules .turbo-tsconfig.json tsconfig.tsbuildinfo",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "AKASH_CHAT_API_KEY": {
        "type": "string",
        "description": "API key for the Akash Chat service"
      }
    }
  },
  "devDependencies": {
    "prettier": "3.5.3",
    "tsup": "8.4.0",
    "@types/node": "^20.11.24"
  }
}