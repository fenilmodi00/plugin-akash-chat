# Akash Chat API Configuration
# Replace with your actual API key from Akash Chat
AKASH_CHAT_API_KEY=your-api-key-here

# Model Configuration
# Available models for different purposes
AKASH_CHAT_SMALL_MODEL=Meta-Llama-3-1-8B-Instruct-FP8
AKASH_CHAT_LARGE_MODEL=Meta-Llama-3-3-70B-Instruct
AKASH_CHAT_EMBEDDING_MODEL=BAAI-bge-large-en-v1-5

# Model Usage Configuration
# Set to false to disable local model usage
USE_STUDIOLM_TEXT_MODELS=false
USE_OLLAMA_TEXT_MODELS=false
USE_OLLAMA_EMBEDDING=false

# Local LLaMA Model Path (if using local models)
LLAMALOCAL_PATH= 